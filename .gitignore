# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
*.whl

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Data & outputs (add exceptions below if needed) ──────────────────────────
data/*.parquet
data/*.csv
data/*.xlsx
outputs/plots/*.html
outputs/plots/*.png
outputs/reports/*.html
outputs/reports/*.pdf

# Keep directory structure in git
!data/.gitkeep
!outputs/plots/.gitkeep
!outputs/reports/.gitkeep

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ── Environment variables ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Docker ────────────────────────────────────────────────────────────────────
.dockerignore

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
